#!/usr/bin/env bash
# Rofi power/session menu with Nerd Font icons

LOCK="ůįĆĺ"
LOGOUT="ůįćÉ"
SUSPEND="ůį§Ą"
REBOOT="ůįúČ"
SHUTDOWN="ůįź•"

chosen=$(printf "%s\n%s\n%s\n%s\n%s" "$LOCK" "$LOGOUT" "$SUSPEND" "$REBOOT" "$SHUTDOWN" | \
    rofi -dmenu -theme catppuccin-macchiato-powermenu -p "Power" -selected-row 0)

[ -z "$chosen" ] && exit 0

confirm_action() {
    local ans
    ans=$(printf "ůįÖĖ\nůįĄ¨" | \
        rofi -dmenu -theme catppuccin-macchiato-confirm -p "Confirm" -mesg "Are you sure?")
    [ "$ans" = "ůįĄ¨" ]
}

case "$chosen" in
    "$LOCK")
        ~/.local/bin/lockscreen
        ;;
    "$LOGOUT")
        confirm_action && i3-msg exit
        ;;
    "$SUSPEND")
        confirm_action && systemctl suspend
        ;;
    "$REBOOT")
        confirm_action && systemctl reboot
        ;;
    "$SHUTDOWN")
        confirm_action && systemctl poweroff
        ;;
esac
